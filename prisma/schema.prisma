generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  status    String   @default("Active") // Active / Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals Proposal[]
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("Member") // Admin, Manager, Member, Viewer
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals Proposal[]
}

model ThematicArea {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals ProposalThematicArea[]
}

model Proposal {
  id               String                @id @default(cuid())
  name             String
  rfpNumber        String                @default("")
  clientId         String
  client           Client                @relation(fields: [clientId], references: [id])
  assignedMemberId String                @default("")
  assignedMember   TeamMember?           @relation(fields: [assignedMemberId], references: [id])
  value            Float                 @default(0)
  status           String                @default("In Process") // Submitted, In Process, In Evaluation, Pending, Won
  remarks          String                @default("")
  deadline         DateTime?
  submissionDate   DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  thematicAreas    ProposalThematicArea[]
}

model ProposalThematicArea {
  id            String       @id @default(cuid())
  proposalId    String
  thematicAreaId String
  proposal      Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  thematicArea  ThematicArea @relation(fields: [thematicAreaId], references: [id], onDelete: Cascade)

  @@unique([proposalId, thematicAreaId])
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  filePath  String   @default("")
  fileType  String   @default("")
  fileSize  Int      @default(0)
  fileData  String   @default("") // base64 encoded file content for serverless storage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String @id @default(cuid())
  key       String @unique
  value     String @default("")
}
