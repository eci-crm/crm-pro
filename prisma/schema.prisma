generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  status    String   @default("Active") // Active / Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals Proposal[]
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("Member") // Admin, Manager, Member, Viewer
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals Proposal[]
}

model ThematicArea {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proposals ProposalThematicArea[]
}

model Proposal {
  id                String                @id @default(cuid())
  name              String
  rfpNumber         String                @default("")
  clientId          String
  client            Client                @relation(fields: [clientId], references: [id])
  assignedMemberId  String                @default("")
  assignedMember    TeamMember?           @relation(fields: [assignedMemberId], references: [id])
  value             Float                 @default(0)
  status            String                @default("In Process") // Submitted, In Process, In Evaluation, Pending, Won
  winningChances    String                @default("") // Low, Medium, High
  focalPerson       String                @default("")
  followupDate      DateTime?
  linkedProposalId  String?
  linkedProposal    Proposal?             @relation("LinkedProposals", fields: [linkedProposalId], references: [id])
  remarks           String                @default("")
  deadline          DateTime?
  submissionDate    DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  thematicAreas     ProposalThematicArea[]
  linkedFrom        Proposal[]            @relation("LinkedProposals")
}

model ProposalThematicArea {
  id            String       @id @default(cuid())
  proposalId    String
  thematicAreaId String
  proposal      Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  thematicArea  ThematicArea @relation(fields: [thematicAreaId], references: [id], onDelete: Cascade)

  @@unique([proposalId, thematicAreaId])
}

model ResourceFolder {
  id        String    @id @default(cuid())
  name      String
  parentId  String?
  parent    ResourceFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ResourceFolder[] @relation("FolderHierarchy")
  resources Resource[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  filePath  String   @default("")
  fileType  String   @default("")
  fileSize  Int      @default(0)
  fileData  String   @default("") // base64 encoded file content for serverless storage
  folderId  String?
  folder    ResourceFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String @id @default(cuid())
  key       String @unique
  value     String @default("")
}
